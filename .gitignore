# Virtual environment (never commit — recreated via requirements.txt)
ml_env/
venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Data (too large, changes often — tracked separately or via DVC later)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ML pipeline artifacts (preprocessor, trained baseline models — binary, regenerated)
ml/artifacts/*.joblib
!ml/artifacts/.gitkeep

# MLflow tracking data (local experiment logs, not code)
mlruns/
mlflow.db

# Jupyter checkpoints
.ipynb_checkpoints/

# Environment secrets
.env
configs/kaggle/kaggle.json

# OS/editor junk
.vscode/
.DS_Store

# ML pipeline artifacts (preprocessor, baseline models — binary, regenerated)
ml/artifacts/*.joblib
!ml/artifacts/.gitkeep