# Virtual environment (never commit — recreated via requirements.txt)
ml_env/
venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Data (too large, changes often — tracked separately or via DVC later)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Trained models (binary, regenerated by training scripts)
models/*.pkl
models/*.joblib
!models/.gitkeep

# MLflow tracking data (local experiment logs, not code)
mlruns/

# Jupyter checkpoints
.ipynb_checkpoints/

# Environment secrets
.env
configs/kaggle/kaggle.json

# OS/editor junk
.vscode/
.DS_Store